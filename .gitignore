# === Eclipse ===
# Ignora archivos de clase compilados
*.class

# Ignora archivos de configuración del proyecto de Eclipse
.project
.classpath
.settings/

# Ignora configuraciones de lanzamiento
*.launch

# Ignora archivos generados por Eclipse
.externalToolBuilders/
.apt_generated/

# Ignora la carpeta de salida de compilación
bin/
target/

# === Java Común ===
# Ignora archivos de paquete
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar

# Ignora logs de crash de la VM de Java
hs_err_pid*
*.log


# === Docker ===
# Ignora logs y configuraciones locales
docker-compose.override.yml
docker-compose.local.yml
docker-logs/
*.log

# ¡MUY IMPORTANTE!
# Ignora las carpetas de volúmenes de datos
# (donde Docker guarda los datos de la BBDD)
data/
mysql_data/
postgres_data/
db_data/
volumes/